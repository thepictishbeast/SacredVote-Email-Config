# Hard-block any private DKIM/TLS material from ever being committed.
# If a real value lives in this repo it's a leak — rotate immediately.

# DKIM private keys
*.private
opendkim/keys/**/*.private
opendkim/keys/**/*.key

# TLS / dovecot private material
*.pem
*.crt
*.key
private/

# Real env files (templates only — `.example` is allowed)
*.env
!*.env.example
env/*.env
!env/*.env.example
*.real.env
*.real.txt

# Real dovecot user file (hashes — only `users.example` is committed)
dovecot/users
!dovecot/users.example

# Mail spool / per-user mail
vmail/
Maildir/

# OS / editor noise
.DS_Store
*.swp
*~
