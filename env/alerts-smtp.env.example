# /etc/sacred-vote/alerts-smtp.env — credentials for `alerts@sacredvote.org`
# used by plausiden-watchtower's EmailSink (Page-severity alerts only;
# see Mailroom/SECURITY.md and feedback_email_important_items rules).
#
# NEVER use tim@sacred.vote as the From — that mailbox is off-limits for
# automated mail per feedback_no_tim_email_sender (HARD).
#
# Mode 600.
SMTP_HOST="mail.sacred.vote"
SMTP_PORT="587"
SMTP_USER="alerts@sacredvote.org"
SMTP_PASS="<REDACTED-SMTP-PASSWORD-24+chars>"
SMTP_FROM="alerts@sacredvote.org"
