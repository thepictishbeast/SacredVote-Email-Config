# /etc/caddy/cloudflare.env — Cloudflare API token for Caddy's DNS-01
# ACME challenge against sacred.vote and sacredvote.org zones.
#
# Sourced by /etc/systemd/system/caddy.service.d/cloudflare.conf.
# Token scope MUST be: DNS:Edit on sacred.vote and sacredvote.org zones only.
# Mode 600.
CF_API_TOKEN="<REDACTED-CLOUDFLARE-DNS-EDIT-TOKEN-40+chars>"
